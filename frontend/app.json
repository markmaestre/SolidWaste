{
  "expo": {
    "name": "solidWaste",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/TMFK.png",

    "scheme": ["solidwaste"],

    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.krammaestre.solidwaste",
      "infoPlist": {
        "NSCameraUsageDescription": "SolidWaste uses your camera to scan and classify waste items in real-time for proper disposal.",
        "NSPhotoLibraryUsageDescription": "SolidWaste accesses your photos to classify waste items for proper disposal.",
        "NSPhotoLibraryAddUsageDescription": "SolidWaste saves classified waste images to your photo library.",
        "NSMicrophoneUsageDescription": "Microphone access is not used by this app.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },

    "android": {
      "package": "com.krammaestre.solidwaste",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/TMFK.png",
        "backgroundColor": "#001f3f"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.VIBRATE"
      ]
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/TMF.K.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/TMFK.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#0000FF"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/TMFK.png",
          "color": "#001f3f"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SolidWaste to access your photos to classify waste items and help with proper disposal.",
          "cameraPermission": "Allow SolidWaste to access your camera to scan and classify waste items in real-time.",
          "microphonePermission": false
        }
      ],
      "expo-asset"
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "a1ef8d28-aa47-4b60-9536-7d5cb172031a"
      }
    },

    "owner": "kram_maestre"
  }
}